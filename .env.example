# ============================================================
# Shipyard Hub - Frontend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Default admin credentials (used for first-time login)
VITE_DEFAULT_ADMIN_USERNAME=your_admin_username_here
VITE_DEFAULT_ADMIN_PASSWORD=your_admin_password_here
VITE_DEFAULT_ADMIN_EMAIL=admin@yourdomain.com

# Supabase / API config (leave as placeholder if using local Go server)
VITE_SUPABASE_URL=placeholder
VITE_SUPABASE_ANON_KEY=placeholder
