# ============================================================
# Shipyard Hub - Go Server Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Default admin credentials (used to seed the database on first run)
DEFAULT_ADMIN_USERNAME=your_admin_username_here
DEFAULT_ADMIN_PASSWORD=your_admin_password_here
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com

# JWT secret for authentication — CHANGE THIS IN PRODUCTION!
NEXTAUTH_SECRET=your_very_secure_random_secret_here_change_me

# Server port (default: 3000)
PORT=3000

# Database path
# Local development: ./shipyard.sqlite
# Docker/EasyPanel production: /data/shipyard.sqlite
DATABASE_PATH=/data/shipyard.sqlite

# Timezone
TZ=Asia/Jakarta
